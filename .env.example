# ─── Auth Service ───────────────────────────────────────────
AUTH_PORT=4001
AUTH_MONGO_URI=mongodb://mongo-auth:27017/auth-db
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Patient Service ────────────────────────────────────────
PATIENT_PORT=4002
PATIENT_MONGO_URI=mongodb://mongo-patient:27017/patient-db

# ─── Doctor Service ─────────────────────────────────────────
DOCTOR_PORT=4003
DOCTOR_MONGO_URI=mongodb://mongo-doctor:27017/doctor-db

# ─── Appointment Service ────────────────────────────────────
APPOINTMENT_PORT=4004
APPOINTMENT_MONGO_URI=mongodb://mongo-appointment:27017/appointment-db
AUTH_SERVICE_URL=http://auth-service:4001
DOCTOR_SERVICE_URL=http://doctor-service:4003

# ─── Frontend ───────────────────────────────────────────────
FRONTEND_PORT=3000
REACT_APP_AUTH_URL=http://localhost:4001
REACT_APP_PATIENT_URL=http://localhost:4002
REACT_APP_DOCTOR_URL=http://localhost:4003
REACT_APP_APPOINTMENT_URL=http://localhost:4004
